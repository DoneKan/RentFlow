# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://your-app.up.railway.app
# Comma-separated list of allowed frontend origins
CLIENT_URL=https://your-app.vercel.app,http://localhost:5173

# ── Database (Railway PostgreSQL — copy from Railway dashboard) ───────────────
DATABASE_URL=postgresql://postgres:password@hostname:5432/railway

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=generate_with_openssl_rand_base64_32
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=generate_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ── Mobile Money (MTN MoMo) ───────────────────────────────────────────────────
MTN_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_API_USER=your_mtn_api_user
MTN_API_KEY=your_mtn_api_key
MTN_ENVIRONMENT=sandbox

# ── Mobile Money (Airtel) ─────────────────────────────────────────────────────
AIRTEL_API_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_ENVIRONMENT=sandbox

# ── Africa's Talking (SMS) ────────────────────────────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=RentFlow

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=RentFlow <noreply@rentflow.ug>
